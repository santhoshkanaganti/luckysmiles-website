# Get your free API key at https://resend.com
# Add this in Vercel Dashboard → Settings → Environment Variables
RESEND_API_KEY=re_your_api_key_here

# The email address that will RECEIVE contact form submissions
CONTACT_EMAIL=your@email.com

# The email address Resend sends FROM (must be verified in Resend dashboard)
# Use onboarding@resend.dev for testing, or your own verified domain email
FROM_EMAIL=onboarding@resend.dev
